# -----------------------------------------------------------------------------
# Auth mode (REQUIRED to be explicit when overriding the default)
#   static  -> use ACCESS_TOKEN as the required ?key= and ALLOWED_ORIGINS for CORS.
#              AUTH_BASE_URL is ignored.
#   dynamic -> call AUTH_BASE_URL on every request to validate ?key= and fetch
#              per-key allowed_origins (existing behavior).
#   unset   -> treated as 'dynamic' (backward compatible).
#   Any other value -> server refuses to start.
# At startup the server validates that the env vars required for the selected
# mode are present (static -> ACCESS_TOKEN; dynamic -> AUTH_BASE_URL).
# -----------------------------------------------------------------------------
AUTH_MODE=dynamic


# -----------------------------------------------------------------------------
# Timezone (consumed automatically by Node via env_file; no code change needed).
# Set to any valid IANA timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
# -----------------------------------------------------------------------------
TZ=UTC


# -----------------------------------------------------------------------------
# Dynamic-mode vars (used only when AUTH_MODE=dynamic)
# -----------------------------------------------------------------------------
# Base URL of the validation API. Required when AUTH_MODE=dynamic.
# For local dev with Docker: http://host.docker.internal:5010
AUTH_BASE_URL=


# -----------------------------------------------------------------------------
# Static-mode vars (used only when AUTH_MODE=static)
# -----------------------------------------------------------------------------
# Static access token(s). Clients must send a matching value as ?key=<token>.
# Accepts a single token or a comma-separated list for multiple tokens; any
# match authenticates the request. Whitespace around tokens is trimmed.
# Required when AUTH_MODE=static.
#   Examples:
#     ACCESS_TOKEN=secret-token-123
#     ACCESS_TOKEN=client-a-token,client-b-token,client-c-token
# -----------------------------------------------------------------------------
ACCESS_TOKEN=

# Comma-separated list of allowed origins for CORS in static mode.
# Domain-only (protocol stripped at match time). Wildcards supported:
#   example.com            -> exact hostname match
#   *                      -> allow all origins (equivalent to IS_CHECK_ALLOWED_ORIGINS=false)
ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Shared (applies to both modes)
# -----------------------------------------------------------------------------
# Set to false to allow ALL origins (disables origin checking entirely).
# When false, both static and dynamic modes serve CORS '*'.
IS_CHECK_ALLOWED_ORIGINS=true
